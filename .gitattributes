# Normalize line endings to LF in the repo (Reduces CRLF/LF warnings on Windows)
* text=auto eol=lf

# Windows scripts keep CRLF if you add any
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
